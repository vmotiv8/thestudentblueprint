# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@your-host:5432/postgres

# Email (Resend)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=Your App <hello@yourdomain.com>

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AI (Google Gemini)
GEMINI_API_KEY=your-gemini-api-key

# AI (Anthropic Claude)
ANTHROPIC_API_KEY=your-anthropic-api-key

# College Scorecard API (US Dept of Education)
COLLEGE_SCORECARD_API_KEY=your-college-scorecard-api-key

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ROOT_DOMAIN=thestudentblueprint.com
# Note: ROOT_DOMAIN stays as the bare domain for subdomain routing
# APP_URL should be https://app.thestudentblueprint.com in production

# Vercel API (for custom domain provisioning)
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_TEAM_ID=


